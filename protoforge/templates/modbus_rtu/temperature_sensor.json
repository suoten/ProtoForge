{
    "id": "modbus_rtu_temperature_sensor",
    "name": "RTU温湿度传感器",
    "protocol": "modbus_rtu",
    "description": "基于RS-485串口的Modbus RTU温湿度传感器，适用于远距离工业现场",
    "manufacturer": "Generic",
    "model": "TH-RTU-100",
    "points": [
        {
            "name": "temperature",
            "address": "0",
            "data_type": "float32",
            "unit": "°C",
            "description": "环境温度",
            "access": "r",
            "generator_type": "random",
            "min_value": 15.0,
            "max_value": 35.0
        },
        {
            "name": "humidity",
            "address": "1",
            "data_type": "float32",
            "unit": "%RH",
            "description": "环境湿度",
            "access": "r",
            "generator_type": "random",
            "min_value": 30.0,
            "max_value": 80.0
        },
        {
            "name": "dew_point",
            "address": "2",
            "data_type": "float32",
            "unit": "°C",
            "description": "露点温度",
            "access": "r",
            "generator_type": "random",
            "min_value": 5.0,
            "max_value": 25.0
        }
    ],
    "protocol_config": {
        "slave_id": 1,
        "baudrate": 9600,
        "parity": "none",
        "stopbits": 1
    },
    "tags": ["环境监控", "温度", "湿度", "RS-485"]
}
