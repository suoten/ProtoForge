            "access": "r",
            "generator_type": "random",
            "min_value": 5.0,
            "max_value": 30.0
        },
        {
            "name": "power_factor",
            "address": "5",
            "data_type": "float32",
            "unit": "",
            "description": "功率因数",
            "access": "r",
            "generator_type": "random",
            "min_value": 0.85,
            "max_value": 0.98
        }
    ],
    "protocol_config": {
        "slave_id": 2,
        "baudrate": 9600,
        "parity": "even",
        "stopbits": 1
    },
    "tags": ["电力", "仪表", "RS-485"]
