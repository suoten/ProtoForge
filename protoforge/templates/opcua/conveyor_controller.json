{
    "id": "opcua_conveyor",
    "name": "输送线控制器",
    "protocol": "opcua",
    "description": "自动化输送线OPC UA控制器，支持多段皮带速度、传感器状态、分拣控制",
    "manufacturer": "Generic",
    "model": "CV-1000",
    "points": [
        {
            "name": "belt1_speed",
            "address": "ns=2;s=Conveyor.Belt1.Speed",
            "data_type": "float32",
            "unit": "m/s",
            "description": "1号皮带速度",
            "access": "rw",
            "generator_type": "random",
            "min_value": 0.0,
            "max_value": 2.0
        },
        {
            "name": "belt2_speed",
            "address": "ns=2;s=Conveyor.Belt2.Speed",
            "data_type": "float32",
            "unit": "m/s",
            "description": "2号皮带速度",
            "access": "rw",
            "generator_type": "random",
            "min_value": 0.0,
            "max_value": 2.0
        },
        {
            "name": "belt1_running",
            "address": "ns=2;s=Conveyor.Belt1.Running",
            "data_type": "bool",
            "description": "1号皮带运行",
            "access": "rw",
            "generator_type": "fixed",
            "fixed_value": true
        },
        {
            "name": "belt2_running",
            "address": "ns=2;s=Conveyor.Belt2.Running",
            "data_type": "bool",
            "description": "2号皮带运行",
            "access": "rw",
            "generator_type": "fixed",
            "fixed_value": true
        },
        {
            "name": "sensor_entry",
            "address": "ns=2;s=Conveyor.Sensor.Entry",
            "data_type": "bool",
            "description": "入口光电传感器",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        },
        {
            "name": "sensor_exit",
            "address": "ns=2;s=Conveyor.Sensor.Exit",
            "data_type": "bool",
            "description": "出口光电传感器",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        },
        {
            "name": "sorter_position",
            "address": "ns=2;s=Conveyor.Sorter.Position",
            "data_type": "uint16",
            "description": "分拣器位置(0=左 1=中 2=右)",
            "access": "rw",
            "generator_type": "fixed",
            "fixed_value": 1
        },
        {
            "name": "item_count",
            "address": "ns=2;s=Conveyor.ItemCount",
            "data_type": "uint16",
            "description": "通过件数",
            "access": "r",
            "generator_type": "random",
            "min_value": 0,
            "max_value": 9999
        },
        {
            "name": "jam_alarm",
            "address": "ns=2;s=Conveyor.Alarm.Jam",
            "data_type": "bool",
            "description": "堵料报警",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        }
    ],
    "protocol_config": {},
    "tags": ["输送线", "物流", "自动化", "OPC-UA"]
}
