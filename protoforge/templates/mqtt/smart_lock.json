{
    "id": "mqtt_smart_lock",
    "name": "智能门锁",
    "protocol": "mqtt",
    "description": "物联网智能门锁，支持MQTT远程控制，适用于智慧楼宇、公寓管理",
    "manufacturer": "Generic",
    "model": "SL-200",
    "points": [
        {
            "name": "lock_state",
            "address": "protoforge/{device_id}/lock/state",
            "data_type": "bool",
            "description": "门锁状态(true=锁定 false=开锁)",
            "access": "rw",
            "generator_type": "fixed",
            "fixed_value": true
        },
        {
            "name": "battery_level",
            "address": "protoforge/{device_id}/lock/battery",
            "data_type": "uint16",
            "unit": "%",
            "description": "电池电量",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 85
        },
        {
            "name": "door_state",
            "address": "protoforge/{device_id}/lock/door",
            "data_type": "bool",
            "description": "门磁状态(true=关 false=开)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": true
        },
        {
            "name": "alarm_tamper",
            "address": "protoforge/{device_id}/lock/alarm",
            "data_type": "bool",
            "description": "防撬报警",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        },
        {
            "name": "last_unlock_method",
            "address": "protoforge/{device_id}/lock/method",
            "data_type": "uint16",
            "description": "上次开锁方式(0=指纹 1=密码 2=卡片 3=APP 4=钥匙)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 0
        }
    ],
    "protocol_config": {},
    "tags": ["门锁", "智能楼宇", "IoT", "安防"]
}
