            "access": "r",
            "generator_type": "random",
            "min_value": 180.0,
            "max_value": 220.0
        },
        {
            "name": "reactor_pressure",
            "address": "Reactor.Pressure",
            "data_type": "float32",
            "unit": "MPa",
            "description": "反应釜压力",
            "access": "r",
            "generator_type": "random",
            "min_value": 1.0,
            "max_value": 3.5
        },
        {
            "name": "feed_rate",
            "address": "Feed.Rate",
            "data_type": "float32",
            "unit": "L/h",
            "description": "进料流量",
            "access": "rw",
            "generator_type": "sine",
            "min_value": 50,
            "max_value": 200
        },
        {
            "name": "level",
            "address": "Tank.Level",
            "data_type": "float32",
            "unit": "%",
            "description": "液位",
            "access": "r",
            "generator_type": "sine",
            "min_value": 20,
            "max_value": 90
        },
        {
            "name": "product_quality",
            "address": "Quality.Index",
            "data_type": "float32",
