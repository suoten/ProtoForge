            "description": "产品质量指标",
            "access": "r",
            "generator_type": "random",
            "min_value": 95.0,
            "max_value": 99.9
        },
        {
            "name": "alarm_count",
            "address": "System.AlarmCount",
            "data_type": "int32",
            "description": "活动报警数",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 0
        }
    ],
    "protocol_config": {
        "server_name": "ProtoForge.OPCDA.Simulator",
        "update_rate": 1000
    },
    "tags": ["OPC-DA", "SCADA", "DCS", "化工", "过程控制"]
