{
    "id": "fanuc_0if_plus",
    "name": "FANUC 0i-F Plus CNC",
    "protocol": "fanuc",
    "description": "FANUC 0i-F Plus数控系统，FOCAS2协议通信，支持坐标/速度/报警/程序信息采集",
    "manufacturer": "FANUC",
    "model": "0i-F Plus",
    "points": [
        {
            "name": "run_mode",
            "address": "cnc_mode",
            "data_type": "uint16",
            "description": "运行模式(1=MDI 3=AUTO 4=EDIT 5=HANDLE)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 3
        },
        {
            "name": "execution_status",
            "address": "cnc_execution",
            "data_type": "uint16",
            "description": "执行状态(1=RUN 2=STOP 3=HOLD)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 1
        },
        {
            "name": "x_absolute",
            "address": "abs_x",
            "data_type": "float32",
            "unit": "mm",
            "description": "X轴绝对坐标",
            "access": "r",
            "generator_type": "sine",
            "min_value": -200,
            "max_value": 200
        },
        {
            "name": "y_absolute",
            "address": "abs_y",
            "data_type": "float32",
            "unit": "mm",
            "description": "Y轴绝对坐标",
            "access": "r",
            "generator_type": "sine",
            "min_value": -150,
            "max_value": 150
        },
        {
            "name": "z_absolute",
            "address": "abs_z",
            "data_type": "float32",
            "unit": "mm",
            "description": "Z轴绝对坐标",
            "access": "r",
            "generator_type": "sine",
            "min_value": -100,
            "max_value": 300
        },
        {
            "name": "spindle_speed",
            "address": "spindle_speed",
            "data_type": "float32",
            "unit": "RPM",
            "description": "主轴转速",
            "access": "r",
            "generator_type": "random",
            "min_value": 1000,
            "max_value": 8000
        },
        {
            "name": "feed_rate",
            "address": "feed_rate",
            "data_type": "float32",
            "unit": "mm/min",
            "description": "进给速度",
            "access": "r",
            "generator_type": "random",
            "min_value": 100,
            "max_value": 5000
        },
        {
            "name": "alarm_status",
            "address": "alarm",
            "data_type": "uint16",
            "description": "报警数量(0=无报警)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 0
        },
        {
            "name": "program_name",
            "address": "program",
            "data_type": "string",
            "description": "当前程序名",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": "O0001"
        }
    ],
    "protocol_config": {
        "cnc_type": "0i-F",
        "focas_version": 2
    },
    "tags": ["CNC", "FANUC", "数控", "FOCAS", "机加工"]
