            "max_value": 3.0,
            "generator_config": {
                "script": "elapsed = context['elapsed']; base = 0.6 + 0.4 * math.sin(2 * math.pi * elapsed / 80 + 0.5); noise = random.uniform(-0.2, 0.2); result = round(max(0.1, base + noise), 3)"
            }
        },
        {
            "name": "vibration_y",
            "address": "vibration_y",
            "data_type": "float32",
            "unit": "m/s²",
            "description": "Y轴振动加速度",
