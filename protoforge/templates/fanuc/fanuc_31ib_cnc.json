            "max_value": 3.0,
            "generator_config": {
                "script": "elapsed = context['elapsed']; base = 0.6 + 0.4 * math.sin(2 * math.pi * elapsed / 65 + 1.5); noise = random.uniform(-0.2, 0.2); result = round(max(0.1, base + noise), 3)"
            }
        },
        {
            "name": "vibration_z",
            "address": "vibration_z",
