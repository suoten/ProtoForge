            "description": "调光等级",
            "access": "rw",
            "generator_type": "fixed",
            "fixed_value": 80.0
        },
        {
            "name": "lux_level",
            "address": "analogInput,1",
            "data_type": "float32",
            "unit": "lux",
            "description": "照度值",
            "access": "r",
            "generator_type": "random",
            "min_value": 100.0,
            "max_value": 800.0
        },
        {
            "name": "occupancy",
            "address": "binaryInput,1",
            "data_type": "bool",
            "description": "人体感应",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": true
        },
        {
            "name": "scene_id",
            "address": "analogOutput,2",
