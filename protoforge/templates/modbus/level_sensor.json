            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        },
        {
            "name": "alarm_low",
            "address": "10",
            "data_type": "bool",
            "description": "低液位报警",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        }
