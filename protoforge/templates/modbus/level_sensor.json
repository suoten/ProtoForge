            "access": "r",
            "generator_type": "random",
            "min_value": 0.0,
            "max_value": 100.0
        },
        {
            "name": "volume",
            "address": "4",
            "data_type": "float32",
            "unit": "m³",
            "description": "储罐体积",
            "access": "r",
            "generator_type": "random",
            "min_value": 0.0,
            "max_value": 5000.0
        },
        {
            "name": "temperature",
            "address": "6",
            "data_type": "float32",
