        },
        {
            "name": "alarm_low",
            "address": "2",
            "data_type": "bool",
            "description": "低浓度报警",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": false
        },
        {
            "name": "sensor_status",
            "address": "3",
            "data_type": "bool",
            "description": "传感器状态",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": true
        }
