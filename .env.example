# ============================================
# ProtoForge 核心配置
# ============================================

# Web 服务监听地址和端口
PROTOFORGE_HOST=0.0.0.0
PROTOFORGE_PORT=8000

# 数据库配置
# SQLite（默认，适合开发和单机部署）：
PROTOFORGE_DB_PATH=data/protoforge.db
# PostgreSQL（生产环境推荐）：
# PROTOFORGE_DB_PATH=postgresql://user:password@localhost:5432/protoforge?sslmode=require

# JWT 密钥（重要：生产环境必须修改！）
# 留空将在首次启动时自动生成随机密钥，但重启后所有 Token 会失效
# 生产环境请设置为 32 字节以上的随机字符串：python -c "import secrets; print(secrets.token_urlsafe(32))"
PROTOFORGE_JWT_SECRET=

# 演示模式（启动时自动创建示例设备）
PROTOFORGE_DEMO_MODE=false

# 日志级别：debug, info, warning, error
PROTOFORGE_LOG_LEVEL=info

# CORS 允许源（多个用逗号分隔，默认 * 允许所有）
# 生产环境建议设置为具体域名，如：https://protoforge.example.com
PROTOFORGE_CORS_ORIGINS=*

# 禁用认证（仅用于开发和测试，生产环境切勿启用）
# PROTOFORGE_NO_AUTH=false

# 管理员初始密码（默认: admin，生产环境必须设置强密码！）
PROTOFORGE_ADMIN_PASSWORD=admin

# 最小密码长度（默认: 4，生产环境建议设为 8+）
PROTOFORGE_MIN_PASSWORD_LENGTH=4

# Token 有效期（秒）
# PROTOFORGE_ACCESS_TOKEN_EXPIRES=86400
# PROTOFORGE_REFRESH_TOKEN_EXPIRES=604800

# 登录安全策略
# PROTOFORGE_MAX_LOGIN_ATTEMPTS=5
# PROTOFORGE_LOCKOUT_DURATION=300

# ============================================
# InfluxDB 数据转发配置（可选）
# ============================================
# PROTOFORGE_INFLUXDB_URL=http://localhost:8086
# PROTOFORGE_INFLUXDB_TOKEN=your-influxdb-token
# PROTOFORGE_INFLUXDB_ORG=default
# PROTOFORGE_INFLUXDB_BUCKET=protoforge

# ============================================
# EdgeLite 网关集成配置（可选）
# ============================================
# PROTOFORGE_EDGELITE_URL=http://localhost:8080
# PROTOFORGE_EDGELITE_USERNAME=admin
# PROTOFORGE_EDGELITE_PASSWORD=

# ============================================
# 协议端口配置
# ============================================

PROTOFORGE_MODBUS_TCP_PORT=5020
# PROTOFORGE_MODBUS_RTU_PORT=  (留空自动识别：Windows=COM1, Linux=/dev/ttyUSB0)
PROTOFORGE_OPCUA_PORT=4840
PROTOFORGE_MQTT_PORT=1883
PROTOFORGE_HTTP_PORT=8080
PROTOFORGE_GB28181_PORT=5060
PROTOFORGE_BACNET_PORT=47808
PROTOFORGE_S7_PORT=102
PROTOFORGE_MC_PORT=5000
PROTOFORGE_FINS_PORT=9600
PROTOFORGE_AB_PORT=44818
PROTOFORGE_OPCDA_PORT=51340
PROTOFORGE_FANUC_PORT=8193
PROTOFORGE_MTCONNECT_PORT=7878
PROTOFORGE_TOLEDO_PORT=1701
PROTOFORGE_PROFINET_PORT=34964
PROTOFORGE_ETHERCAT_PORT=34980

# ============================================
# 高可用/故障转移配置（可选）
# ============================================
# PROTOFORGE_FAILOVER_ROLE=primary
# PROTOFORGE_FAILOVER_PRIMARY=http://localhost:8000
# PROTOFORGE_FAILOVER_STANDBY=http://localhost:8001
# PROTOFORGE_FAILOVER_INTERVAL=10

# ============================================
# gRPC 服务配置（可选，默认禁用）
# 设为 0 禁用，设为端口号（如 50051）启用
# ============================================
PROTOFORGE_GRPC_PORT=0

# ============================================
# API 限流配置
# ============================================
# PROTOFORGE_RATE_LIMIT_MAX_REQUESTS=100
# PROTOFORGE_RATE_LIMIT_WINDOW_SECONDS=60
# PROTOFORGE_RATE_LIMIT_AUTH_MAX_REQUESTS=10
# PROTOFORGE_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
